{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --experimental-transform-types src/server.ts",
    "start": "node --experimental-transform-types src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@scalar/express-api-reference": "^0.10.2",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@azure/msal-node": "^5.2.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
